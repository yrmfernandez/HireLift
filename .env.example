# Get a free key at https://console.groq.com (no credit card required)
GROQ_API_KEY=your_groq_api_key_here

# Optional: add more keys from other Groq accounts to raise your effective
# rate limit. Each account has its own independent TPM budget, and the app
# round-robins across all keys and fails over when one is rate-limited.
# Add up to GROQ_API_KEY_10. Leave blank if you only have one key.
#
# NOTE: Using multiple free accounts to bypass rate limits may conflict with
# Groq's terms of service. The sanctioned path for higher limits is their paid
# Dev tier. Fine for a personal/portfolio project — just know the tradeoff.
# GROQ_API_KEY_2=your_second_groq_api_key_here

# Optional: override the default port
PORT=3000

# Set to true to run without an API key (canned responses) — useful for
# frontend development and testing without burning Groq rate limits.
MOCK_MODE=false
